        "    optimizer=tf.keras.optimizers.Adam(\n",
        "        learning_rate=1e-4\n",
        "    ),\n",
        "    loss=\"categorical_crossentropy\",\n",
        "    metrics=[\"accuracy\"]\n",
        ")"
