    {
      "cell_type": "code",
      "source": [
        "x = base_model.output\n",
        "\n",
        "x = GlobalAveragePooling2D()(x)\n",
        "\n",
        "x = BatchNormalization()(x)\n",
        "\n",
        "x = Dropout(0.5)(x)\n",
        "\n",
        "x = Dense(\n",
        "    512,\n",
        "    activation=\"relu\"\n",
        ")(x)\n",
        "\n",
        "x = Dropout(0.3)(x)\n",
        "\n",
        "output = Dense(\n",
        "    5,\n",
        "    activation=\"softmax\"\n",
        ")(x)\n",
        "\n",
        "model = Model(\n",
        "    inputs=base_model.input,\n",
        "    outputs=output\n",
        ")"
      ],
      "metadata": {
        "id": "CMaeZsFsY24c"
      },
      "execution_count": 48,
      "outputs": []
