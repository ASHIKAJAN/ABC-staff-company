    {
      "cell_type": "code",
      "source": [
        "PREPROCESS_PATH = \"/content/preprocessed\"\n",
        "\n",
        "os.makedirs(PREPROCESS_PATH, exist_ok=True)"
      ],
      "metadata": {
        "id": "WtHuhhvDTVRJ"
