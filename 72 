      "execution_count": 21,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "IMG_SIZE = 380\n",
        "\n",
        "def preprocess_image(path):\n",
        "\n",
        "    img = cv2.imread(path)\n",
        "\n",
        "    if img is None:\n",
        "        return None\n",
        "\n",
        "    img = cv2.cvtColor(\n",
        "        img,\n",
        "        cv2.COLOR_BGR2RGB\n",
        "    )\n",
        "\n",
        "    # Remove black borders\n",
        "    gray = cv2.cvtColor(\n",
        "        img,\n",
        "        cv2.COLOR_RGB2GRAY\n",
        "    )\n",
        "\n",
        "    _, thresh = cv2.threshold(\n",
        "        gray,\n",
        "        10,\n",
        "        255,\n",
        "        cv2.THRESH_BINARY\n",
        "    )\n",
        "\n",
        "    coords = cv2.findNonZero(thresh)\n",
        "\n",
        "    if coords is not None:\n",
        "        x, y, w, h = cv2.boundingRect(coords)\n",
        "        img = img[y:y+h, x:x+w]\n",
        "\n",
        "    # Resize\n",
        "    img = cv2.resize(\n",
        "        img,\n",
        "        (IMG_SIZE, IMG_SIZE)\n",
        "    )\n",
        "\n",
        "    # CLAHE\n",
        "    lab = cv2.cvtColor(\n",
        "        img,\n",
        "        cv2.COLOR_RGB2LAB\n",
        "    )\n",
        "\n",
        "    l, a, b = cv2.split(lab)\n",
        "\n",
        "    clahe = cv2.createCLAHE(\n",
        "        clipLimit=2.0,\n",
        "        tileGridSize=(8,8)\n",
        "    )\n",
        "\n",
        "    l = clahe.apply(l)\n",
        "\n",
        "    lab = cv2.merge((l,a,b))\n",
        "\n",
        "    img = cv2.cvtColor(\n",
        "        lab,\n",
        "        cv2.COLOR_LAB2RGB\n",
        "    )\n",
        "\n",
        "    return img"
      ],
      "metadata": {
        "id": "UHldW6X_T0Sv"
      },
      "execution_count": 25,
      "outputs": []
    },
